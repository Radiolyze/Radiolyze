HUGGINGFACE_HUB_TOKEN=hf_xxx

# For local development (without Docker), set proxy targets:
# VITE_API_PROXY_TARGET=http://localhost:8000
# VITE_DICOM_WEB_PROXY_TARGET=http://localhost:8042

# Prompt configuration (backend)
# PROMPT_CONFIG_ENABLED=true
# PROMPT_CACHE_TTL=30
# PROMPT_MAX_LENGTH=4000
# VLLM_SCHEMA_STRICT=false

# vLLM runtime defaults (used by backend; matches docker-compose vllm-medgemma command)
# VLLM_MAX_TOKENS=4096
# VLLM_GUIDED_JSON=true
# VLLM_TEMPERATURE=0.1
# VLLM_TOP_P=0.9
# Note: vllm-medgemma serves with --max-model-len 32768 to fit MedGemma 1.5
# 3D volume inputs (up to 85 axial slices ~ 21,760 vision tokens). Lowering
# this caps the 3D pipeline; raising requires more KV-cache VRAM.

# DICOMweb credentials (if authentication required)
# VITE_DICOM_WEB_USERNAME=orthanc
# VITE_DICOM_WEB_PASSWORD=orthanc
# DICOMweb base URL for backend data capture
# DICOM_WEB_BASE_URL=http://localhost:8042/dicom-web
# DICOM_WEB_USERNAME=orthanc
# DICOM_WEB_PASSWORD=orthanc

# Inference frame sampling (frontend)
# VITE_INFERENCE_MAX_FRAMES_CURRENT=16
# VITE_INFERENCE_MAX_FRAMES_PRIOR=8

# --- Whisper ASR overlay (docker/compose/whisper.yml) ---
# WHISPER_MODEL=base          # base / small / medium / large-v3
# WHISPER_DEVICE=cpu          # cpu / cuda
# WHISPER_LANGUAGE=auto
# WHISPER_COMPUTE_TYPE=int8

# --- Drift Monitoring Scheduler ---
# DRIFT_SCHEDULE_HOURS=24     # Interval in hours; set to 0 to disable
# DRIFT_WINDOW_DAYS=7         # Current window for drift calculation
# DRIFT_BASELINE_DAYS=7       # Baseline window for comparison

# --- 3D Segmentation Microservice ---
# SEGMENTER_URL=http://segmenter:8200
# SEGMENTATION_DATA_DIR=/data/segmentations
# SEGMENTATION_JOB_TIMEOUT=1800      # Hard timeout per segmentation job (s)
# SEGMENTATION_POLL_INTERVAL=3       # RQ worker polls segmenter every N s
# BONE_HU_THRESHOLD=300              # HU cutoff for the bone preset
# SEGMENTER_MAX_PARALLEL_WADO=8      # Concurrent WADO instance fetches
# SEGMENTATION_AUDIT_MESH_DOWNLOADS=false  # Set true for compliance reviews; emits one audit event per mesh/mask GET
# MESH_MAX_FACES=20000               # Per-label decimation ceiling; small organs auto-scale below this
# SEGMENTATION_GENERATE_DICOM_SEG=true  # Set false to skip the DICOM SEG export pass (saves ~5-15s + pydicom-seg dep)

# --- MedGemma 3D volume preprocessor (segmenter side) ---
# MEDGEMMA_VOLUME_MAX_SLICES=64       # Slices sent to MedGemma per volume (<=85 per model card)
# MEDGEMMA_VOLUME_WINDOW_PRESET=auto  # auto | lung | mediastinum | bone | abdomen | mr (per-modality fallback)
# MEDGEMMA_VOLUME_STRATEGY=uniform    # uniform | central (slice-selection)
# MEDGEMMA_VOLUME_RESIZE=896          # Output side length (MedGemma SigLIP tile)
# SEGMENTER_PREPROCESS_TIMEOUT=120
